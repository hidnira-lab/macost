# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000 is correct for local web dev
# (npm run dev against the local FastAPI dev server).
#
# Tauri desktop builds are different: apps/native/src-tauri/tauri.conf.json's
# beforeBuildCommand runs `cd ../web && npm run build`, and Next.js inlines
# NEXT_PUBLIC_* variables at build time (not runtime) -- whatever value is
# present in the environment/.env.local at that moment gets baked permanently
# into the built desktop app.
#
# For a Tauri desktop build intended for real use, set
# NEXT_PUBLIC_API_BASE_URL=https://macost-production.up.railway.app before
# running the Tauri build. Otherwise the packaged app will keep calling
# localhost:8000, which does not exist on an end user's machine.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCK=false
